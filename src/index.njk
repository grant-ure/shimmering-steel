<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ site.title }}</title>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<nav>
  <div class="nav-links" id="nav-links">
    {% for section in collections.sections %}
    <a {% if loop.first %}class="active" {% endif %}data-section="{{ section.data.slug }}" href="#{{ section.data.slug }}">{{ section.data.nav_label }}</a>
    {% endfor %}
  </div>
  <button class="hamburger" id="hamburger" onclick="toggleMenu()" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-menu" id="mobile-menu">
  {% for section in collections.sections %}
  <a {% if loop.first %}class="active" {% endif %}data-section="{{ section.data.slug }}" href="#{{ section.data.slug }}">{{ section.data.nav_label }}</a>
  {% endfor %}
</div>

<div class="hero">
  <div class="hero-title">{{ site.hero_title }}</div>
  <div class="hero-subtitle">{{ site.hero_subtitle }}</div>
</div>

{% for section in collections.sections %}
<div class="content-section{% if loop.first %} active-section{% endif %}" id="section-{{ section.data.slug }}">
  <h2 class="section-title">{{ section.data.title }}</h2>
  <div class="section-rule"></div>
  {% if section.data.gallery and section.data.gallery.length %}
  <div class="gallery-grid">
    {% for item in section.data.gallery %}
    <div class="gallery-thumb"><img src="{{ item.image }}" alt="{{ section.data.title }}" loading="lazy"></div>
    {% endfor %}
  </div>
  {% endif %}
  <div class="section-body{% if section.data.layout_style == 'two-column' %} body-2col{% endif %}">
    {{ section.templateContent | safe }}
  </div>
  {% if section.data.slug == 'costs' %}{% include "partials/cost-table.njk" %}{% endif %}
  {% if section.data.slug == 'contact' %}{% include "partials/contact-form.njk" %}{% endif %}
</div>
{% endfor %}

<footer>{{ site.footer | safe }}</footer>

<div class="lightbox" id="lightbox">
  <button class="lightbox-close" onclick="closeLightbox()">&times;</button>
  <img id="lb-img" src="" alt="Shimmering Steel">
  <div class="lb-nav">
    <button class="lb-btn" onclick="lbMove(-1)">&#8249; Prev</button>
    <button class="lb-btn" onclick="lbMove(1)">Next &#8250;</button>
  </div>
</div>

<script src="/js/main.js" defer></script>

<!-- Netlify Identity: redirects editors to the CMS after they accept an invite -->
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", (user) => {
      if (!user) {
        window.netlifyIdentity.on("login", () => {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>
</body>
</html>
