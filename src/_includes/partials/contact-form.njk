{# Contact form submitted to Netlify Forms via AJAX (see main.js).
   The recipient email is configured in the Netlify dashboard:
   Site -> Forms -> contact -> Settings & usage -> Form notifications. #}
<form class="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
  <input type="hidden" name="form-name" value="contact">
  <p hidden><label>Leave this field empty if you're human: <input name="bot-field"></label></p>

  <div class="form-group">
    <label for="name">Name *</label>
    <input type="text" id="name" name="name" placeholder="Your name">
    <span class="form-error" id="err-name">Please enter your name.</span>
  </div>
  <div class="form-group">
    <label for="email">Email Address *</label>
    <input type="email" id="email" name="email" placeholder="your@email.com">
    <span class="form-error" id="err-email">Please enter a valid email address.</span>
  </div>
  <div class="form-group">
    <label for="contact-number">Contact Number</label>
    <input type="tel" id="contact-number" name="contact-number" placeholder="Optional">
  </div>
  <div class="form-group">
    <label for="query">Your Query *</label>
    <textarea id="query" name="query" placeholder="Please let us know the nature of your query…"></textarea>
    <span class="form-error" id="err-query">Please enter your query.</span>
  </div>
  <button type="submit" class="submit-btn">Submit</button>
  <p class="form-success" id="form-success">Thanks — your enquiry has been sent. We'll be in touch.</p>
</form>
